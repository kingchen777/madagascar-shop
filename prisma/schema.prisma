generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Users & Addresses
// ─────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  email     String?   @unique
  phone     String?   @unique
  name      String?
  role      Role      @default(CUSTOMER)
  locale    String    @default("fr")
  orders    Order[]
  addresses Address[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  fullName  String
  phone     String
  region    String
  line1     String
  note      String?
  isDefault Boolean @default(false)
}

// ─────────────────────────────────────────────
// Categories
// ─────────────────────────────────────────────

model Category {
  id           String                @id @default(cuid())
  slug         String                @unique
  parentId     String?
  parent       Category?             @relation("Tree", fields: [parentId], references: [id])
  children     Category[]            @relation("Tree")
  translations CategoryTranslation[]
  products     Product[]
  sort         Int                   @default(0)
  createdAt    DateTime              @default(now())
}

model CategoryTranslation {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale     String
  name       String

  @@unique([categoryId, locale])
}

// ─────────────────────────────────────────────
// Products
// ─────────────────────────────────────────────

model Product {
  id            String               @id @default(cuid())
  slug          String               @unique
  type          ProductType          @default(SELF)
  source        SourcePlatform       @default(NONE)
  sourceUrl     String?
  categoryId    String?
  category      Category?            @relation(fields: [categoryId], references: [id])
  basePriceCNY  Decimal?             @db.Decimal(12, 2)
  priceMGA      Decimal?             @db.Decimal(14, 2)
  serviceFeePct Decimal?             @db.Decimal(5, 2)
  weightKg      Decimal?             @db.Decimal(8, 3)
  stock         Int?
  status        ProductStatus        @default(DRAFT)
  images        ProductImage[]
  translations  ProductTranslation[]
  orderItems    OrderItem[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

enum ProductType {
  SELF
  AGENT
}

enum SourcePlatform {
  NONE
  TAOBAO
  TMALL
  PINDUODUO
  JD
  ALIBABA1688
  OTHER
}

enum ProductStatus {
  DRAFT
  ACTIVE
  HIDDEN
  SOLD_OUT
}

model ProductTranslation {
  id          String  @id @default(cuid())
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale      String
  name        String
  description String  @db.Text
  isAuto      Boolean @default(false)

  @@unique([productId, locale])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sort      Int     @default(0)
}

// ─────────────────────────────────────────────
// Orders
// ─────────────────────────────────────────────

model Order {
  id               String      @id @default(cuid())
  orderNo          String      @unique
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  type             ProductType
  status           OrderStatus @default(DRAFT)
  items            OrderItem[]
  payments         Payment[]
  productCost      Decimal     @default(0) @db.Decimal(14, 2)
  domesticShipping Decimal     @default(0) @db.Decimal(14, 2)
  intlShipping     Decimal     @default(0) @db.Decimal(14, 2)
  serviceFee       Decimal     @default(0) @db.Decimal(14, 2)
  customsFee       Decimal     @default(0) @db.Decimal(14, 2)
  miscFee          Decimal     @default(0) @db.Decimal(14, 2)
  depositAmount    Decimal     @default(0) @db.Decimal(14, 2)
  totalAmount      Decimal     @default(0) @db.Decimal(14, 2)
  currency         String      @default("MGA")
  shippingInfo     Json?
  internalNotes    String?     @db.Text
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

enum OrderStatus {
  DRAFT
  QUOTED
  DEPOSIT_PENDING
  DEPOSIT_PAID
  PROCURING
  PURCHASED
  AT_CN_WAREHOUSE
  BALANCE_PENDING
  BALANCE_PAID
  INTL_SHIPPING
  ARRIVED_MG
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product? @relation(fields: [productId], references: [id])
  customUrl     String?
  titleSnapshot String
  spec          String?
  qty           Int      @default(1)
  unitPriceCNY  Decimal? @db.Decimal(12, 2)
  unitPriceMGA  Decimal  @db.Decimal(14, 2)
}

// ─────────────────────────────────────────────
// Payments
// ─────────────────────────────────────────────

model Payment {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id])
  kind        PaymentKind
  provider    PaymentProvider
  amount      Decimal         @db.Decimal(14, 2)
  currency    String          @default("MGA")
  status      PaymentStatus   @default(PENDING)
  providerRef String?
  proofUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum PaymentKind {
  DEPOSIT
  BALANCE
  FULL
}

enum PaymentProvider {
  MVOLA
  ORANGE_MONEY
  AIRTEL_MONEY
  STRIPE
  PAYPAL
  BANK_TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─────────────────────────────────────────────
// Global Settings
// ─────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
